{
  "kind": "collectionType",
  "collectionName": "tamanhos",
  "info": {
    "singularName": "tamanho",
    "pluralName": "tamanhos",
    "displayName": "Tamanho"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nome": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "nome",
      "required": true
    },
    "ordem": {
      "type": "integer"
    },
    "ativo": {
      "type": "boolean",
      "default": true
    },
    "produtos": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::produto.produto",
      "mappedBy": "tamanhos"
    }
  }
}
