{
  "kind": "collectionType",
  "collectionName": "cores",
  "info": {
    "singularName": "cor",
    "pluralName": "cores",
    "displayName": "Cor"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nome": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "nome",
      "required": true
    },
    "hex": {
      "type": "string",
      "required": true
    },
    "ativo": {
      "type": "boolean",
      "default": true
    },
    "produtos": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::produto.produto",
      "mappedBy": "cores"
    }
  }
}
